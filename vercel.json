{
  "headers": [
    {
      "source": "/en/:path*",
      "headers": [
        { "key": "Content-Language", "value": "en" }
      ]
    },
    {
      "source": "/((?!en/|en$|admin).*)",
      "headers": [
        { "key": "Content-Language", "value": "es" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
